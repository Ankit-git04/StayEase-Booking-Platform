<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error-404</title>
    <link href="/output.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen flex items-center justify-center">
    <div class="text-center max-w-md px-4">
      <div class="mb-8">
        <p class="text-9xl font-black text-red-500 mb-4">404</p>
        <h1 class="text-4xl font-bold text-gray-900 mb-3">Page Not Found</h1>
        <p class="text-lg text-gray-600 mb-8">The page you're looking for doesn't exist. It might have been removed or the link may be incorrect.</p>
      </div>
      <a href="/" class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition transform hover:scale-105">Go Back Home</a>
    </div>
</body>
</html>