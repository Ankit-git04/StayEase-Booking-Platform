<%- include('../partials/head', { pageTitle: 'Sign Up' }) %>
</head>
<body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen">
    <%- include('../partials/Navbar') %>
    <main class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="bg-white rounded-2xl shadow-lg p-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-2">Sign Up</h2>
        <p class="text-gray-600 mb-8">Create a new account</p>
         <div class="mb-6">
          <% if (typeof errorMessage !== 'undefined' && errorMessage && errorMessage.length > 0) { %>
            <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg mb-6">
              <div class="flex items-start">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="ml-3">
                  <p class="text-sm font-medium text-red-800"><%= errorMessage %></p>
                </div>
              </div>
            </div>
          <% } %>
             
        <form action="/auth/signup" method="POST" class="space-y-6">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Username</label>
            <input type="text" name="username" value="<%= typeof oldInput !== 'undefined' && oldInput.username ? oldInput.username: '' %>" placeholder="Choose a username" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
            <input type="email" name="email" value="<%= typeof oldInput !== 'undefined' && oldInput.email ? oldInput.email: '' %>" placeholder="your@email.com" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition" />
          </div>
           
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
            <input type="password" name="password" placeholder="••••••••" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition" />
          </div>
 
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-3">Confirm Password</label>
            <input type="password" name="confirmPassword" value="<%= typeof oldInput !== 'undefined' && oldInput.confirmPassword ? oldInput.confirmPassword: '' %>" placeholder="••••••••" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition" />
          </div>

          <!-- User Type Selection -->
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-3">I am a:</label>
            <div class="space-y-2">
              <div class="flex items-center">
                <input type="radio" id="guest" name="userType" value="guest" <%= (typeof oldInput !== 'undefined' && oldInput.userType === 'guest') ? 'checked' : '' %> required class="w-4 h-4 text-red-500 cursor-pointer" />
                <label for="guest" class="ml-3 text-sm text-gray-700 cursor-pointer">Guest</label>
              </div>
              <div class="flex items-center">
                <input type="radio" id="host" name="userType" value="host" <%= (typeof oldInput !== 'undefined' && oldInput.userType === 'host') ? 'checked' : '' %> required class="w-4 h-4 text-red-500 cursor-pointer" />
                <label for="host" class="ml-3 text-sm text-gray-700 cursor-pointer">Host</label>
              </div>
            </div>
          </div>

          <!-- Terms and Conditions -->
          <div class="flex items-start p-4 bg-gray-50 rounded-lg border border-gray-200">
            <input type="checkbox" id="terms" name="terms" value="true" required class="w-4 h-4 mt-1 text-red-500 cursor-pointer accent-red-500" />
            <label for="terms" class="ml-3 text-sm text-gray-700 cursor-pointer">
              I agree to the <span class="text-red-500 font-semibold">Terms & Conditions</span>
            </label> 
          </div>
        
          <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-lg transition transform hover:scale-105">Sign Up</button>
        </form>

        <p class="text-center text-gray-600 mt-6">
          Already have an account? <a href="/auth/login" class="text-red-500 hover:text-red-600 font-semibold">Login</a>
        </p>
      </div>
    </main>
</body>
</html>
