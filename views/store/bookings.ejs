
  <%- include('../partials/head', { pageTitle: 'Bookings' }) %>
  </head>
  <body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen">
    <!-- Navbar --> 
    <%- include('../partials/Navbar') %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
       
    
     

      <!--  HomesList Section -->
     <section class="p-6 bg-gray-100">

  <h3 class="text-2xl sm:text-3xl font-bold mb-6 text-center">
    Your Bookings
  </h3>

  <% if (bookings.length === 0) { %>
    <!-- Empty State -->
    <div class="bg-white rounded-2xl shadow-lg p-12 text-center max-w-2xl mx-auto">
      <div class="mb-6">
        <svg class="w-24 h-24 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-3m0 0l7-4 7 4M5 9v7a1 1 0 001 1h12a1 1 0 001-1V9m-9 16l-7-4m0 0V5a1 1 0 011-1h12a1 1 0 011 1v7m-9 4l7 4"></path>
        </svg>
      </div>
      <h4 class="text-2xl font-bold text-gray-800 mb-3">No Homes Booked Yet</h4>
      <p class="text-gray-600 text-lg mb-8">Book your perfect stay today. It only takes a few minutes to reserve your spot!</p>
      <a href="/" class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition transform hover:scale-105">
        Book Your First Home
      </a>
    </div>
  <% } else { %>
    <!-- GRID ADDED HERE -->
    <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-6">

     <% bookings.forEach(booking => { %>

<li class="bg-white rounded-xl shadow-md hover:shadow-lg transition duration-300 overflow-hidden flex flex-col">

  <img src="<%= booking.homeId.homeImage %>"
       alt="<%= booking.homeId.homeName %>"
       class="w-full h-40 object-cover">

  <div class="p-4 flex flex-col flex-grow">

    <h4 class="text-lg font-semibold text-gray-800 mb-1">
      <%= booking.homeId.homeName %>
    </h4>

    <p class="text-gray-500 text-sm mb-3">
      📍 <%= booking.homeId.location %>
    </p>

    <div class="bg-gray-50 p-3 rounded-lg mb-3 text-sm space-y-1">
      <div class="flex justify-between">
        <span class="text-gray-600">Check-in:</span>
        <span class="font-semibold">
          <%= new Date(booking.checkInDate).toLocaleDateString() %>
        </span>
      </div>

      <div class="flex justify-between">
        <span class="text-gray-600">Check-out:</span>
        <span class="font-semibold">
          <%= new Date(booking.checkOutDate).toLocaleDateString() %>
        </span>
      </div>

      <div class="flex justify-between">
        <span class="text-gray-600">Nights:</span>
        <span class="font-semibold">
          <%= booking.numberOfNights %>
        </span>
      </div>

      <div class="flex justify-between">
        <span class="text-gray-600">Guests:</span>
        <span class="font-semibold">
          <%= booking.numberOfGuests %>
        </span>
      </div>
    </div>

    <div class="border-t pt-2 mt-auto">
      <div class="flex justify-between text-sm mb-1">
        <span class="text-gray-600">Price/night:</span>
        <span class="font-semibold">
          $<%= booking.pricePerNight %>
        </span>
      </div>

      <div class="flex justify-between text-lg font-bold text-red-500">
        <span>Total:</span>
        <span>
          $<%= booking.totalPrice %>
        </span>
      </div>
    </div>

  </div>

</li>

<% }) %>

    </ul>
  <% } %>

</section>
    </main>
  </body>
</html>
