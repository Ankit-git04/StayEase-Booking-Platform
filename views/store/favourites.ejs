<%- include('../partials/head', { pageTitle: 'My Favourites' }) %>
</head>
<body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen">
  <!-- Navbar -->
  <%- include('../partials/Navbar') %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Header Section -->
    <div class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-2">My Favourites</h1>
      <p class="text-xl text-gray-600">Your curated collection of favourite homes and experiences</p>
    </div>

    <!-- Filter and Sort Section -->
  
 
    <!-- Favourites Container -->
    <section>
      <!-- Favourites Grid -->
      <% if (favouriteHomes && favouriteHomes.length > 0) { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 ">
          <% favouriteHomes.forEach(home => { %>
            <div class="bg-white rounded-xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 p-4">
              
              <!-- Image Section -->
              <div class="relative overflow-hidden bg-gray-200 h-48 rounded-lg mb-4">
                <img src="<%= home.homeImage %>" 
                     alt="<%= home.homeName %>" 
                     class="w-full h-full object-cover hover:scale-110 transition-transform duration-300">

                <div class="absolute bottom-3 left-3 bg-yellow-400 text-gray-800 px-3 py-1 rounded-full text-sm font-bold">
                  ⭐ 4.8
                </div>
              </div>
              
              <!-- Content Section -->
              <div>
                <a href="/<%= home._id %>" class="hover:text-red-500">
                  <h3 class="text-lg font-bold text-gray-800 mb-1"><%= home.homeName %></h3>
                </a>
                <p class="text-gray-600 text-sm mb-3">📍 <%= home.location %></p>

                <!-- Price Section -->
                <div class="flex justify-between items-center">
                  <div>
                    <p class="text-gray-600 text-sm">From</p>
                    <p class="text-2xl font-bold text-gray-900">$<%= home.price %><span class="text-lg text-gray-600">/night</span></p>
                  </div>
                  <form action="/bookings/form/<%= home._id %>" method="GET" style="display: inline;">
                    <button type="submit" class="bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-5 rounded-lg transition transform hover:scale-105">
                      Book Now
                    </button>
                  </form>
                  <form action="/favourites/delete/<%= home._id %>" method="POST" style="display: inline;">
                    <button type="submit" class="bg-red-300 hover:bg-gray-400 text-gray-800 font-semibold py-2 px-5 rounded-lg transition transform hover:scale-105">
                      Remove
                    </button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <!-- Empty State -->
        <div class="bg-white rounded-2xl shadow-lg p-12 text-center max-w-2xl mx-auto">
          <div class="mb-6">
            <svg class="w-24 h-24 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <h4 class="text-2xl font-bold text-gray-800 mb-3">No Favorites Yet</h4>
          <p class="text-gray-600 text-lg mb-8">Start adding homes to your favorites to see them here!</p>
          <a href="/" class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition transform hover:scale-105">
            Browse Homes
          </a>
        </div>
      <% } %>
    </section>

   

  </main>

</body>
</html>