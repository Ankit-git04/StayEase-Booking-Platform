<%- include('../partials/head', { pageTitle: home.homeName }) %>
</head>
<body class="bg-gray-50 min-h-screen">
  <!-- Navbar -->
  <%- include('../partials/Navbar') %>

  <main class="max-w-4xl mx-auto px-4 py-8">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 p-6">
        
        <!-- Image Section -->
        <div class="md:col-span-1">
          <img src="<%= home.homeImage %>" alt="<%= home.homeName %>" class="w-full h-48 object-cover rounded-lg" />
        </div>

        <!-- Details Section -->
        <div class="md:col-span-2 flex flex-col justify-between">
          <div>
            <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= home.homeName %></h1>
            <p class="text-gray-600 mb-3 text-sm">📍 <%= home.location %></p>
            
            <!-- Info Cards -->
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div class="bg-gray-50 p-3 rounded-lg">
                <p class="text-xs text-gray-500 uppercase">Price per night</p>
                <p class="text-lg font-bold text-red-500">$<%= home.price %></p>
              </div>
              <div class="bg-gray-50 p-3 rounded-lg">
                <p class="text-xs text-gray-500 uppercase">Type</p>
                <p class="text-sm font-semibold text-gray-800">Home</p>
                <p class="text-sm text-gray-600">Lorem, ipsum dolor sit amet consectetur adipisicing elit. Quasi sit, error non sint tenetur nulla?lorem100</p>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex gap-2">
            <form action="/favourites/<%= home._id %>" method="POST" class="flex-1">
              <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded-lg transition text-sm">
                 Favourite
              </button>
            </form> 
            <form action="/bookings/form/<%= home._id %>" method="GET" class="flex-1">
              <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-4 rounded-lg transition text-sm">
                Book Now
              </button>
            </form>
           
          </div>
        </div>

      </div>
    </div>
  </main>
</body>
</html>
